{
    "$schema": "../validation-test-schema.json",
    "description": "maxItems validation",
    "tests": [
        {
            "description": "maxItems validation",
            "compatibility": "3",
            "schema": { "maxItems": 2 },
            "tests": [
                {
                    "description": "shorter is valid",
                    "data": [1],
                    "valid": true
                },
                {
                    "description": "exact length is valid",
                    "data": [1, 2],
                    "valid": true
                },
                {
                    "description": "too long is invalid",
                    "data": [1, 2, 3],
                    "valid": false
                },
                {
                    "description": "ignores non-arrays",
                    "data": "foobar",
                    "valid": true
                }
            ]
        },
        {
            "description": "maxItems validation with a decimal",
            "compatibility": "6",
            "schema": { "maxItems": 2.0 },
            "tests": [
                {
                    "description": "shorter is valid",
                    "data": [1],
                    "valid": true
                },
                {
                    "description": "too long is invalid",
                    "data": [1, 2, 3],
                    "valid": false
                }
            ]
        }
    ]
}
