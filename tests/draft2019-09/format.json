[
    {
        "description": "email format",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "format": "email"
        },
        "tests": [
            {
                "description": "all string formats ignore integers",
                "data": 12,
                "valid": true
            },
            {
                "description": "all string formats ignore floats",
                "data": 13.7,
                "valid": true
            },
            {
                "description": "all string formats ignore objects",
                "data": {},
                "valid": true
            },
            {
                "description": "all string formats ignore arrays",
                "data": [],
                "valid": true
            },
            {
                "description": "all string formats ignore booleans",
                "data": false,
                "valid": true
            },
            {
                "description": "all string formats ignore nulls",
                "data": null,
                "valid": true
            },
            {
                "description": "a valid email address",
                "data": "test@example.com",
                "valid": true
            },
            {
                "description": "email with subdomain",
                "data": "test@sub.example.com",
                "valid": true
            },
            {
                "description": "email with '+' in local part",
                "data": "test+alias@example.com",
                "valid": true
            },
            {
                "description": "empty string is not an email",
                "data": "",
                "valid": false
            },
            {
                "description": "just a string is not an email",
                "data": "test",
                "valid": false
            },
            {
                "description": "missing local part",
                "data": "@example.com",
                "valid": false
            },
            {
                "description": "missing domain",
                "data": "test@",
                "valid": false
            },
            {
                "description": "domain contains invalid characters",
                "data": "test@ex@mple.com",
                "valid": false
            },
            {
                "description": "local part contains invalid characters",
                "data": "test\"@example.com",
                "valid": false
            }
        ]
    },
